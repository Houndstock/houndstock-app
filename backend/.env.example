# Houndstock backend env vars. Copy to .env and edit as needed.
# .env is gitignored; .env.example is committed.

# Port the Ktor server binds to. Default: 8080.
PORT=8080

# Postgres connection string. Not used yet — added when the data layer lands.
# DATABASE_URL=postgres://houndstock:houndstock@localhost:5432/houndstock

# Set to "true" to enable Ktor development mode (hot reload, dev banner).
DEVELOPMENT_MODE=false
